{
  "name": "kroyer-figma-plugin",
  "version": "0.2.0",
  "private": true,
  "description": "Krøyer — Figma plugin for searching public-domain artworks from Statens Museum for Kunst (SMK). Search, filter, drag-to-insert, save collections, extract palettes, export mood boards. Named after the Danish painter P.S. Krøyer.",
  "license": "MIT",
  "scripts": {
    "dev": "run-p watch:ui watch:plugin",
    "watch:ui": "vite build --watch",
    "watch:plugin": "vite build --mode plugin --watch",
    "build:ui": "vite build",
    "build:plugin": "vite build --mode plugin",
    "build": "npm run build:plugin && npm run build:ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.100.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
