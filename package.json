{
  "name": "smk-figma-plugin",
  "version": "0.0.1",
  "private": true,
  "description": "Figma plugin for searching and inserting artworks from Statens Museum for Kunst (SMK).",
  "license": "MIT",
  "scripts": {
    "dev": "run-p watch:ui watch:plugin",
    "watch:ui": "vite build --watch",
    "watch:plugin": "vite build --mode plugin --watch",
    "build:ui": "vite build",
    "build:plugin": "vite build --mode plugin",
    "build": "npm run build:plugin && npm run build:ui",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
